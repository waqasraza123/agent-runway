{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runway.local/contracts/worker/agent-turn.schema.json",
  "title": "Agent worker turn execution",
  "type": "object",
  "required": ["request", "response"],
  "additionalProperties": false,
  "properties": {
    "request": {
      "$ref": "#/$defs/LlmTurnRequest"
    },
    "response": {
      "$ref": "#/$defs/LlmExecutionOutcome"
    }
  },
  "$defs": {
    "AgentExecutionProfile": {
      "type": "object",
      "required": ["agent_name", "backend", "max_retries"],
      "additionalProperties": false,
      "properties": {
        "agent_name": { "type": "string", "minLength": 1 },
        "backend": { "enum": ["deterministic", "llm"] },
        "llm_provider_name": { "type": ["string", "null"], "minLength": 1 },
        "model_name": { "type": ["string", "null"], "minLength": 1 },
        "temperature": { "type": ["number", "null"], "minimum": 0, "maximum": 2 },
        "max_output_tokens": { "type": ["integer", "null"], "minimum": 1 },
        "timeout_seconds": { "type": ["number", "null"], "exclusiveMinimum": 0 },
        "max_retries": { "type": "integer", "minimum": 0 }
      }
    },
    "TaskRecord": {
      "type": "object",
      "required": [
        "task_id",
        "title",
        "description",
        "assigned_agent",
        "status",
        "dependency_ids",
        "acceptance_criteria",
        "risk_level",
        "attempt_count"
      ],
      "additionalProperties": false,
      "properties": {
        "task_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "assigned_agent": { "type": "string", "minLength": 1 },
        "status": {
          "enum": [
            "pending",
            "ready",
            "in_progress",
            "blocked",
            "awaiting_verification",
            "awaiting_approval",
            "completed",
            "failed",
            "skipped"
          ]
        },
        "dependency_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "acceptance_criteria": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "risk_level": { "enum": ["low", "medium", "high", "critical"] },
        "attempt_count": { "type": "integer", "minimum": 0 }
      }
    },
    "LlmTurnRequest": {
      "type": "object",
      "required": [
        "run_id",
        "user_goal",
        "task",
        "execution_profile",
        "available_tool_names"
      ],
      "additionalProperties": false,
      "properties": {
        "run_id": { "type": "string", "minLength": 1 },
        "user_goal": { "type": "string", "minLength": 1 },
        "task": { "$ref": "#/$defs/TaskRecord" },
        "execution_profile": { "$ref": "#/$defs/AgentExecutionProfile" },
        "available_tool_names": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "PlannedToolCall": {
      "type": "object",
      "required": ["tool_name", "tool_input"],
      "additionalProperties": false,
      "properties": {
        "tool_name": { "type": "string", "minLength": 1 },
        "tool_input": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "StructuredTurnOutput": {
      "type": "object",
      "required": ["summary", "planned_tool_calls"],
      "additionalProperties": false,
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "planned_tool_calls": {
          "type": "array",
          "items": { "$ref": "#/$defs/PlannedToolCall" }
        }
      }
    },
    "LlmUsage": {
      "type": "object",
      "required": ["input_tokens", "output_tokens", "total_tokens"],
      "additionalProperties": false,
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 },
        "estimated_cost_usd": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "LlmTurnResponse": {
      "type": "object",
      "required": ["provider_name", "model_name", "output", "usage"],
      "additionalProperties": false,
      "properties": {
        "provider_name": { "type": "string", "minLength": 1 },
        "model_name": { "type": "string", "minLength": 1 },
        "output": { "$ref": "#/$defs/StructuredTurnOutput" },
        "usage": { "$ref": "#/$defs/LlmUsage" },
        "finish_reason": { "type": ["string", "null"] },
        "latency_ms": { "type": ["integer", "null"], "minimum": 0 },
        "raw_response_text": { "type": ["string", "null"] }
      }
    },
    "LlmExecutionOutcome": {
      "type": "object",
      "required": ["output", "fallback_used", "attempt_count"],
      "additionalProperties": false,
      "properties": {
        "output": { "$ref": "#/$defs/StructuredTurnOutput" },
        "llm_response": {
          "anyOf": [{ "$ref": "#/$defs/LlmTurnResponse" }, { "type": "null" }]
        },
        "error_message": { "type": ["string", "null"] },
        "fallback_used": { "type": "boolean" },
        "attempt_count": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
